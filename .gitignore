# Dependencies
node_modules/
# NOTE: package-lock.json is intentionally committed per MCP best practices
# for reproducible builds. Do NOT ignore it.

# Environment variables
.env
.env.local
.env.*.local

# MCP configuration (contains API keys)
.mcp.json

# Generated images (from testing)
*.png
*.jpg
*.jpeg
*.webp

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output

# Compiled binary addons
build/Release

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
